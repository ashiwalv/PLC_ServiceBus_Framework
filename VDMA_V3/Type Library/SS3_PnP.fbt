<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="SS3_PnP" Comment="Basic FB with empty ECC" >
	<Identification Standard="61499-2">
	</Identification>
	<VersionInfo Version="1.0" Author="DEVIASH" Date="2025-08-24">
	</VersionInfo>
	<CompilerInfo>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="PLACE_LID" Type="Event">
				<With Var="pos_x"/>
				<With Var="pos_y"/>
				<With Var="pos_z"/>
			</Event>
			<Event Name="BASE_FLIPPED" Type="Event">
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="NEXT_LID" Type="Event">
			</Event>
			<Event Name="FLIP_BASE" Type="Event">
			</Event>
		</EventOutputs>
		<InputVars>
