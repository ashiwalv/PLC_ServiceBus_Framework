			<VarDeclaration Name="pos_y" Type="REAL"/>
			<VarDeclaration Name="pos_z" Type="REAL"/>
		</InputVars>
	</InterfaceList>
	<BasicFB>
		<ECC>
			<ECState Name="START" Comment="Initial State"  x="550" y="425">
			</ECState>
			<ECState Name="State" x="2000" y="1706.67">
			</ECState>
			<ECTransition Source="START" Destination="State" Condition="1" Comment="" x="1460" y="1146.67"/>
			<ECTransition Source="State" Destination="START" Condition="1" Comment="" x="1393.33" y="1186.67"/>
		</ECC>
	</BasicFB>
</FBType>
