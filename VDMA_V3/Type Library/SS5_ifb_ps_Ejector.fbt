			<Connection Source="PUBLISH_FIXED.CNF" Destination="DONE" dx1="300"/>
			<Connection Source="PUBLISH_START_AIR_NOZZLE.CNF" Destination="DONE" dx1="300"/>
			<Connection Source="PUBLISH_STOP_AIR_NOZZLE.CNF" Destination="DONE" dx1="300"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="ID_SUB_FIX" Destination="SUBSCRIBE_FIX.ID" dx1="300"/>
			<Connection Source="ID_SUB_RELEASED" Destination="SUBSCRIBE_RELEASED.ID" dx1="300"/>
			<Connection Source="ID_SUB_CHECK_SPEED_DONE" Destination="SUBSCRIBE_CHECK_SPEED_DONE.ID" dx1="300"/>
			<Connection Source="ID_PUB_S5_DONE" Destination="PUBLISH_S5_DONE.ID" dx1="300"/>
			<Connection Source="ID_PUB_CHECK_SPEED" Destination="PUBLISH_CHECK_SPEED.ID" dx1="300"/>
			<Connection Source="ID_PUB_FIXED" Destination="PUBLISH_FIXED.ID" dx1="300"/>
