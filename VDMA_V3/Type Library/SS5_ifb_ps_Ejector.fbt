			<VarDeclaration Name="ID_SUB_RELEASED" Type="WSTRING"/>
			<VarDeclaration Name="ID_SUB_CHECK_SPEED_DONE" Type="WSTRING"/>
			<VarDeclaration Name="ID_PUB_S5_DONE" Type="WSTRING"/>
			<VarDeclaration Name="ID_PUB_CHECK_SPEED" Type="WSTRING"/>
			<VarDeclaration Name="ID_PUB_FIXED" Type="WSTRING"/>
			<VarDeclaration Name="ID_PUB_START_AIR_NOZZLE" Type="WSTRING"/>
			<VarDeclaration Name="ID_PUB_STOP_AIR_NOZZLE" Type="WSTRING"/>
		</InputVars>
		<OutputVars>
			<VarDeclaration Name="Status" Type="WSTRING" Comment="Output event qualifier" />
		</OutputVars>
	</InterfaceList>
	<FBNetwork>
		<FB Name="SS5_ifb_Ejector_Instance" Type="UserLibs::SubStations::SS5::SS5_ifb_Ejector" x="2800" y="500">
		</FB>
		<FB Name="SUBSCRIBE_FIX" Type="SUBSCRIBE_0" x="500" y="-500">
			<Parameter Name="QI" Value="1"/>
		</FB>
		<FB Name="SUBSCRIBE_RELEASED" Type="SUBSCRIBE_0" x="1800" y="-400">
			<Parameter Name="QI" Value="1"/>
		</FB>
		<FB Name="SUBSCRIBE_CHECK_SPEED_DONE" Type="SUBSCRIBE_0" x="2900" y="-500">
			<Parameter Name="QI" Value="1"/>
		</FB>
		<FB Name="PUBLISH_S5_DONE" Type="PUBLISH_0" x="500" y="1300">
			<Parameter Name="QI" Value="1"/>
		</FB>
		<FB Name="PUBLISH_CHECK_SPEED" Type="PUBLISH_0" x="1700" y="1300">
			<Parameter Name="QI" Value="1"/>
		</FB>
		<FB Name="PUBLISH_FIXED" Type="PUBLISH_0" x="2900" y="1300">
			<Parameter Name="QI" Value="1"/>
		</FB>
		<FB Name="PUBLISH_START_AIR_NOZZLE" Type="PUBLISH_0" x="4100" y="1300">
			<Parameter Name="QI" Value="1"/>
		</FB>
		<FB Name="PUBLISH_STOP_AIR_NOZZLE" Type="PUBLISH_0" x="5300" y="1300">
			<Parameter Name="QI" Value="1"/>
		</FB>
		<EventConnections>
			<Connection Source="INIT" Destination="SUBSCRIBE_FIX.INIT" dx1="300"/>
			<Connection Source="SUBSCRIBE_FIX.INITO" Destination="SUBSCRIBE_RELEASED.INIT" dx1="300"/>
			<Connection Source="SUBSCRIBE_RELEASED.INITO" Destination="SUBSCRIBE_CHECK_SPEED_DONE.INIT" dx1="300"/>
			<Connection Source="SUBSCRIBE_CHECK_SPEED_DONE.INITO" Destination="PUBLISH_S5_DONE.INIT" dx1="80" dx2="80" dy="900"/>
			<Connection Source="PUBLISH_S5_DONE.INITO" Destination="PUBLISH_CHECK_SPEED.INIT" dx1="300"/>
			<Connection Source="PUBLISH_CHECK_SPEED.INITO" Destination="PUBLISH_FIXED.INIT" dx1="300"/>
			<Connection Source="PUBLISH_FIXED.INITO" Destination="PUBLISH_START_AIR_NOZZLE.INIT" dx1="300"/>
