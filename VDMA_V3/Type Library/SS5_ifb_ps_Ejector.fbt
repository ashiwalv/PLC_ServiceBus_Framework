			<Connection Source="SUBSCRIBE_CHECK_SPEED_DONE.IND" Destination="SS5_ifb_Ejector_Instance.CHECK_SPEED_DONE" dx1="80" dx2="80" dy="700"/>
			<Connection Source="SS5_ifb_Ejector_Instance.S5_DONE" Destination="PUBLISH_S5_DONE.REQ" dx1="300"/>
			<Connection Source="SS5_ifb_Ejector_Instance.CHECK_SPEED" Destination="PUBLISH_CHECK_SPEED.REQ" dx1="300"/>
			<Connection Source="SS5_ifb_Ejector_Instance.FIXED" Destination="PUBLISH_FIXED.REQ" dx1="300"/>
			<Connection Source="SS5_ifb_Ejector_Instance.START_AIR_NOZZLE" Destination="PUBLISH_START_AIR_NOZZLE.REQ" dx1="300"/>
			<Connection Source="SS5_ifb_Ejector_Instance.STOP_AIR_NOZZLE" Destination="PUBLISH_STOP_AIR_NOZZLE.REQ" dx1="300"/>
			<Connection Source="PUBLISH_S5_DONE.CNF" Destination="DONE" dx1="300"/>
